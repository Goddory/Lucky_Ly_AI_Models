data/selfies/*
!data/selfies/.gitkeep
data/albedo/*
!data/albedo/.gitkeep
data/normal/*
!data/normal/.gitkeep

# Pre-trained weights and checkpoints
weights/*
!weights/.gitkeep

# Training artifacts
checkpoints/
logs/
*.ckpt
*.pth
*.pt

# OS artifacts
.DS_Store
Thumbs.db
